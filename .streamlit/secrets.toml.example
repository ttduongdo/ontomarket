# Copy this to .streamlit/secrets.toml for local use,
# OR paste the key=value pairs into the Streamlit Cloud Secrets UI.
# Never commit secrets.toml to git.

NEO4J_URI      = "neo4j+s://xxxxxxxx.databases.neo4j.io"   # Aura connection URI
NEO4J_USER     = "neo4j"
NEO4J_PASSWORD = "your-aura-password-here"
ANTHROPIC_API_KEY = "sk-ant-..."
